#!/usr/bin/env bash
# adlc — deterministic ADLC operations, LLM-independent and host-independent.
# Any agent (Claude, Gemini, Cline, …) or a human runs these; they never
# require a model. Reasoning stages (spec/code/tests) are done by the agent;
# everything mechanical lives here.
#
# Usage:
#   adlc init "<request>" [KEY]     create docs/adlc/<KEY>/ + state.md (+ local ticket)
#   adlc constitution               create/print docs/adlc/constitution.md (project principles)
#   adlc next-key                   print the next local ticket key (ADLC-00N)
#   adlc status <KEY>               print the state file
#   adlc get-state <KEY> <field>    read one state field
#   adlc set-state <KEY> <f> <v>    write one state field
#   adlc approve <KEY> gate1|gate2  record a human approval
#   adlc branch <KEY>               print/ensure the feature branch name
#   adlc compare-url <branch>       print the PR compare URL from origin
#   adlc ship <KEY> [--no-push]     commit (+push) the change, print compare URL
#
# Jira create/pick lives in jira_ticket.py (needs network); this file is offline.

set -euo pipefail
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib.sh"

cmd="${1:-help}"; shift || true

next_key() {
  local d max=0 n b
  d="$(adlc_dir)/tickets"
  if [ -d "$d" ]; then
    for f in "$d"/ADLC-*.md; do
      [ -e "$f" ] || continue
      b="$(basename "$f" .md)"; n="${b#ADLC-}"
      case "$n" in ''|*[!0-9]*) continue;; esac
      n=$((10#$n)); [ "$n" -gt "$max" ] && max="$n"
    done
  fi
  printf "ADLC-%03d" $((max + 1))
}

compare_url() { # branch
  local url="${1:?branch required}" remote branch="$1"
  remote="$(git remote get-url origin 2>/dev/null || true)"
  [ -n "$remote" ] || { echo ""; return 0; }
  url="${remote%.git}"
  case "$url" in
    git@*:*)      # scp-style: git@host:owner/repo
                  host="${url#git@}"; host="${host%%:*}"
                  path="${url#git@*:}"
                  url="https://$host/$path" ;;
    ssh://git@*)  url="https://${url#ssh://git@}" ;;
  esac
  echo "$url/compare/$branch?expand=1"
}

case "$cmd" in
  next-key) next_key ;;

  jira) # mode|pick|create ...  — delegates to jira_ticket.py with a real interpreter
    py="$(adlc_python)" || die "no working python interpreter found (tried python3/py/python)"
    "$py" "$(adlc_script_dir)/jira_ticket.py" "$@"
    ;;

  init) # "<request>" [KEY]
    req="${1:?request required}"; key="${2:-$(next_key)}"
    mkdir -p "$(key_dir "$key")" "$(adlc_dir)/tickets"
    today="$(date +%Y-%m-%d)"
    slug="$(slugify "$req")"
    branch="${ADLC_BRANCH_PREFIX:-adlc}/$key-$slug"
    # seed state.md from template with substitutions
    sed -e "s|<KEY>|$key|g" -e "s|<TITLE>|$req|g" \
        -e "s|<DATE>|$today|g" -e "s|<BRANCH>|$branch|g" \
        "$(adlc_templates_dir)/state.md" > "$(state_file "$key")"
    # seed a local ticket stub (jira_ticket.py may overwrite in jira mode)
    sed -e "s|<KEY>|$key|g" -e "s|<TITLE>|$req|g" -e "s|<DATE>|$today|g" \
        "$(adlc_templates_dir)/ticket.md" \
        | tee "$(key_dir "$key")/ticket.md" > "$(adlc_dir)/tickets/$key.md"
    echo "$key"
    ;;

  constitution) # create docs/adlc/constitution.md from template if absent; print its path
    cfile="$(adlc_dir)/constitution.md"
    if [ ! -f "$cfile" ]; then
      mkdir -p "$(adlc_dir)"
      today="$(date +%Y-%m-%d)"
      sed -e "s|<DATE>|$today|g" "$(adlc_templates_dir)/constitution.md" > "$cfile"
      echo "created $cfile — edit it to set your project's principles" >&2
    fi
    echo "$cfile"
    ;;

  status)      key="${1:?KEY required}"; cat "$(state_file "$key")" ;;
  get-state)   get_state "${1:?KEY}" "${2:?field}" ;;
  set-state)   set_state "${1:?KEY}" "${2:?field}" "${3:?value}"; echo "ok" ;;

  approve)
    key="${1:?KEY}"; gate="${2:?gate1|gate2}"
    case "$gate" in
      gate1) set_state "$key" gate1_spec_approved true ;;
      gate2) set_state "$key" gate2_push_approved true ;;
      *) die "gate must be gate1 or gate2" ;;
    esac
    log_state "$key" "$gate: approved by user"
    echo "recorded $gate approval for $key"
    ;;

  branch)
    key="${1:?KEY}"; b="$(get_state "$key" branch)"
    [ -n "$b" ] || die "no branch recorded for $key"
    git rev-parse --abbrev-ref HEAD 2>/dev/null | grep -qx "$b" || git switch -c "$b" 2>/dev/null || git switch "$b"
    echo "$b"
    ;;

  compare-url) compare_url "${1:?branch}" ;;

  ship)
    key="${1:?KEY}"; push=1; [ "${2:-}" = "--no-push" ] && push=0
    [ "$(get_state "$key" gate2_push_approved)" = "true" ] || die "gate2 not approved for $key"
    b="$(get_state "$key" branch)"
    git rev-parse --abbrev-ref HEAD 2>/dev/null | grep -qx "$b" || git switch -c "$b" 2>/dev/null || git switch "$b"
    git add -A
    title="$(get_state "$key" title)"
    git commit -q -m "$key: $title" -m "Refs: docs/adlc/$key/spec.md" || echo "adlc: nothing to commit"
    sha="$(git rev-parse --short HEAD)"
    log_state "$key" "ship: committed $sha"
    if [ "$push" = "1" ] && git remote get-url origin >/dev/null 2>&1; then
      if git push -u origin "$b"; then
        log_state "$key" "ship: pushed $b"
        url="$(compare_url "$b")"; [ -n "$url" ] && echo "PR: $url"
      else
        # push failing must not lose the local commit or corrupt state
        echo "adlc: push FAILED — commit $sha kept locally on $b (fix remote/auth, then: git push -u origin $b)" >&2
        log_state "$key" "ship: push FAILED; local commit $sha kept"
      fi
    else
      echo "committed locally only (no remote or --no-push): $sha on $b"
    fi
    set_state "$key" current_stage done
    ;;

  help|*)
    sed -n '2,20p' "$0"
    ;;
esac
