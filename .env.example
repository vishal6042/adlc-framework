# ADLC Framework — configuration
# Copy this file to `.env` and fill in real values, OR export these as shell
# environment variables. NEVER commit a real .env (it is gitignored).
#
# Jira is OPTIONAL. If these are unset, the framework runs in "local ticket"
# mode and writes ticket files under <project>/docs/adlc/tickets/ instead of
# calling Jira. Everything downstream (spec, code, tests, verify, push) works
# the same either way.

# --- Jira Cloud (optional) -------------------------------------------------
# Base URL of your Jira Cloud site, no trailing slash.
JIRA_BASE_URL=https://your-domain.atlassian.net

# The email tied to your Atlassian account.
JIRA_EMAIL=you@example.com

# An Atlassian API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here

# Default project key that new issues are created under (e.g. ADLC, PROJ).
JIRA_PROJECT_KEY=ADLC

# Issue type used when creating tickets. Defaults to "Task" if unset.
JIRA_ISSUE_TYPE=Task

# --- Git (optional) --------------------------------------------------------
# Prefix used for feature branches. Defaults to "adlc" if unset.
# Produces branches like: adlc/ADLC-123-add-health-endpoint
ADLC_BRANCH_PREFIX=adlc
